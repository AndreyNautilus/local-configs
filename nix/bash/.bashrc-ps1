# Define PS1 envvar
# See: https://man7.org/linux/man-pages/man1/bash.1.html#PROMPTING
#
# !! This PS1 is primarily meant to be used on remote servers,
#    it might need some tweaking for proper local usage.
#


# Styles/Colors
PS1_STYLE_GREEN='\[\e[38;5;2m\]'
PS1_STYLE_RED='\[\e[38;5;9m\]'
PS1_STYLE_PURPLE_BOLD='\[\e[1;38;5;13m\]'
PS1_STYLE_REDFG_WHITEBG_BOLD='\[\e[1;38;5;160;48;5;231m\]'

PS1_STYLE_RESET='\[\e[0m\]'

PS1_CLR_BLACKFG_GREENBG='\e[30;48;5;148m'
PS1_CLR_BLACKFG_ORANGEBG='\e[30;48;5;214m'
PS1_CLR_WHITEFG_REDBG='\e[48;5;160m'

# Gather context
function __ps1_last_status {
    if [ "$?" == "0" ]; then
        printf "";
    else
        printf " ! ";
    fi
}

function __ps1_ssh_session {
    if [ -n "$SSH_CLIENT" ] || [ -n "$SSH_TTY" ]; then
        printf "SSH:"
    fi
}

function __ps1_git_branch {
    BRANCH="$(git symbolic-ref --quiet --short HEAD 2>/dev/null)"
    if [ -n "$BRANCH" ]; then
        printf " ⎇ $BRANCH "
    else
        printf ""
    fi
}

function __ps1_git_branch_color {
    if [ -n "$(__ps1_git_branch)" ]; then {
        if   ! (git diff --no-ext-diff --quiet --exit-code 2>/dev/null); then
            printf $PS1_CLR_WHITEFG_REDBG
        elif ! (git diff --cached --no-ext-diff --quiet --exit-code 2>/dev/null); then
            printf $PS1_CLR_BLACKFG_ORANGEBG
        else
            printf $PS1_CLR_BLACKFG_GREENBG
        fi
    } fi
}

# The prompt
PS1="${PS1_STYLE_REDFG_WHITEBG_BOLD}\$(__ps1_last_status)${PS1_STYLE_RESET}\
[\
${PS1_STYLE_GREEN}\u${PS1_STYLE_RESET}\
@\
${PS1_STYLE_RED}\$(__ps1_ssh_session)${PS1_STYLE_RESET}\
${PS1_STYLE_PURPLE_BOLD}\h${PS1_STYLE_RESET} \
\w \
\$(__ps1_git_branch_color)\$(__ps1_git_branch)${PS1_STYLE_RESET}\
]\$ "
